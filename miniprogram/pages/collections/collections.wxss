.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  background: linear-gradient(180deg, #4f46e5 0%, #6366f1 100%);
  color: #fff;
}

.user-block {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.25);
  text-align: center;
  line-height: 72rpx;
  font-weight: 700;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-email {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-hint {
  font-size: 22rpx;
  opacity: 0.85;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  text-align: center;
  line-height: 64rpx;
  font-size: 32rpx;
}

.icon-btn.primary {
  background: #fff;
  color: var(--primary);
  font-weight: 700;
}

.loading-wrap {
  padding: 120rpx;
  text-align: center;
  color: var(--text-secondary);
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.banner-err {
  margin: 24rpx 32rpx;
  padding: 20rpx;
  background: #fef2f2;
  border-radius: 16rpx;
}

.page-scroll {
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

.list-inner {
  padding: 24rpx 32rpx 0;
}

.scroll-footer {
  padding: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.retry-btn {
  margin-top: 24rpx;
  width: 240rpx;
}

.icon-btn.spinning {
  animation: spin 0.8s linear infinite;
}

.collection-card {
  display: flex;
  align-items: center;
}

.col-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.col-body {
  flex: 1;
  min-width: 0;
}

.col-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.col-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 40rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
}

.list-pad {
  height: 160rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.textarea {
  min-height: 120rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  margin: 0;
}
