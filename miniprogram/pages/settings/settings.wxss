.settings-page {
  padding: 24rpx 32rpx;
}

.profile {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 96rpx;
  text-align: center;
  margin-right: 28rpx;
}

.profile-email {
  font-size: 32rpx;
  font-weight: 600;
}

.profile-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.section-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin: 24rpx 0 12rpx 8rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 28rpx;
  gap: 24rpx;
}

.muted {
  color: var(--text-secondary);
  font-size: 24rpx;
  text-align: right;
  flex: 1;
}

.api-url {
  word-break: break-all;
}

.logout-btn {
  margin-top: 64rpx;
  background: #fff !important;
  color: var(--danger) !important;
  border: 2rpx solid #fecaca;
  border-radius: 20rpx;
  font-weight: 600;
}
