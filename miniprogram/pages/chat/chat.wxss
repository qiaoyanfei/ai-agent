.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--surface);
}

.chat-toolbar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}

.tool-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 12rpx;
}

.messages {
  flex: 1;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.suggestions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.chip {
  padding: 14rpx 24rpx;
  background: #fff;
  border: 1rpx solid var(--border);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text);
}

.bubble-row {
  display: flex;
  margin-bottom: 20rpx;
}

.bubble-row.user {
  justify-content: flex-end;
}

.bubble-row.assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 88%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}

.bubble-user {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.bubble-ai {
  background: #fff;
  color: var(--text);
  border: 1rpx solid var(--border);
  border-bottom-left-radius: 8rpx;
}

.bubble-content {
  display: inline;
  word-break: break-word;
}

.cite-link {
  color: var(--primary);
  font-weight: 600;
  padding: 0 4rpx;
}

.cite-disabled {
  color: var(--text-secondary);
}

.typing {
  display: inline;
  color: var(--primary);
  animation: blink 1s infinite;
}

@keyframes blink {
  50% {
    opacity: 0.3;
  }
}

.scroll-pad {
  height: 24rpx;
}

.composer {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border);
}

.composer-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  background: var(--surface);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.send-btn {
  background: var(--primary) !important;
  color: #fff !important;
  border-radius: 20rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
}

.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.4);
  z-index: 50;
}

.drawer {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 78%;
  max-width: 560rpx;
  background: #fff;
  box-shadow: -8rpx 0 32rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.drawer-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
}

.drawer-new {
  color: var(--primary);
  font-size: 28rpx;
}

.drawer-list {
  flex: 1;
  padding: 12rpx 0;
}

.conv-item {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.conv-item.selected {
  background: var(--primary-light);
}

.conv-title {
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.conv-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.drawer-loading,
.drawer-empty {
  padding: 48rpx;
  text-align: center;
  color: var(--text-secondary);
}
