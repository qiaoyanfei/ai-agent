.preview-page {
  min-height: 100vh;
}

.loading-wrap {
  padding: 120rpx;
  text-align: center;
  color: var(--text-secondary);
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.meta-card {
  margin: 24rpx 32rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
}

.meta-title {
  font-size: 30rpx;
  font-weight: 600;
}

.meta-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.open-pdf {
  margin-top: 24rpx;
  width: 100%;
}

.preview-body {
  height: calc(100vh - 280rpx);
  padding: 0 32rpx 32rpx;
}

.text-block {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 28rpx;
  line-height: 1.65;
  border: 1rpx solid var(--border);
}

.highlight-box {
  margin: 20rpx 0;
  padding: 20rpx;
  background: var(--primary-light);
  border-radius: 12rpx;
  border: 2rpx solid rgba(79, 70, 229, 0.35);
}

.pdf-hint {
  padding: 48rpx 32rpx;
  text-align: center;
}

.excerpt-box {
  margin-top: 40rpx;
  text-align: left;
  background: #fff;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
}

.excerpt-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.banner-err {
  margin: 32rpx;
  padding: 24rpx;
  background: #fef2f2;
  border-radius: 16rpx;
}
