.editor-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.filename-readonly {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.flex-grow {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.editor-area {
  flex: 1;
  width: 100%;
  min-height: 60vh;
  padding: 20rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-family: monospace;
  font-size: 26rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.footer {
  margin-top: 24rpx;
}

.save-btn {
  width: 100%;
}

.banner-err {
  margin: 32rpx;
  padding: 24rpx;
  background: #fef2f2;
  border-radius: 16rpx;
}
